export GPG_TTY=$(tty)
gpg-connect-agent updatestartuptty /bye > /dev/null 2>&1

{{- if hasKey .chezmoi.kernel "osrelease" }}
  {{- if contains "microsoft" .chezmoi.kernel.osrelease }}

export SSH_AUTH_SOCK=/run/user/1000/gnupg/S.gpg-agent.ssh

  {{- else }}

export SSH_AUTH_SOCK=/run/user/{{ output "id" "-u" | trim }}/gnupg/S.gpg-agent.ssh

  {{- end }}
{{- end }}

{{- if contains "darwin" .chezmoi.os }}
export SSH_AUTH_SOCK=${HOME}/.gnupg/S.gpg-agent.ssh
{{- end }}

{{- if and (hasKey . "isWork") .isWork }}
[[ -S $HOME/.colima/docker.sock ]] && export DOCKER_HOST=unix://$HOME/.colima/docker.sock
[[ -S $HOME/.colima/docker.sock ]] && export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock
{{- end }}
